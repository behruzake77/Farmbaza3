# ──────────────────────────────────────────────────
# PharmBaseUZ — muhit o'zgaruvchilari namunasi
# Nusxa oling: cp .env.example .env
# Keyin .env ichidagi qiymatlarni o'zgartiring
# ──────────────────────────────────────────────────

# ── Ma'lumotlar bazasi ─────────────────────────────
# SQLite (lokal ishlab chiqish uchun):
USE_SQLITE=True
SQLITE_PATH=pharmbaseuz.db

# PostgreSQL (Render, production uchun):
# USE_SQLITE=False
# POSTGRES_HOST=dpg-xxxxxxxxxxxx.oregon-postgres.render.com
# POSTGRES_PORT=5432
# POSTGRES_DB=pharmbaseuz
# POSTGRES_USER=pharmuser
# POSTGRES_PASSWORD=PAROLINGIZNI_YOZING

# ── Xavfsizlik ────────────────────────────────────
# Kamida 32 ta tasodifiy belgi:
# python -c "import secrets; print(secrets.token_hex(32))"
SITE_SECRET_KEY=o'zgartiring-maxfiy-kalit-123

# ── Admin kirish ──────────────────────────────────
ADMIN_USERNAME=admin
ADMIN_PASSWORD=admin123
# Yoki bcrypt hashi (xavfsizroq):
# ADMIN_PASSWORD_HASH=$2b$12$...

# ── Sayt sozlamalari ──────────────────────────────
SITE_NAME=PharmBaseUZ
SITE_BACKGROUND_URL=
DEBUG=False
LOG_LEVEL=INFO
TIMEZONE=Asia/Tashkent

# ── Rate limiting ─────────────────────────────────
RATE_LIMIT_REQUESTS=30
RATE_LIMIT_MINUTES=1
